# Copy to .env.local for local development, or set in Vercel > Settings > Environment Variables.
#
# WARNING: anything prefixed with VITE_ is compiled into the JavaScript sent to the browser.
# It is NOT secret — it only stays out of the git repository. Never put a real credential,
# API key or payment token in a VITE_ variable.

# --- Admin gate ---------------------------------------------------------------------------------
# Password for the /admin gate. Use a throwaway value (see README on why it is not real security).
VITE_ADMIN_PASSWORD=

# --- Cloud persistence (Supabase) ---------------------------------------------------------------
# BOTH must be set to turn on cross-device booking sync. Leave blank to fall back to per-device
# localStorage (the app still runs). The anon key is public by design — it is safe to ship because
# Row Level Security on the database decides what it can do. Run supabase/schema.sql once first.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Cancellation emails (optional) -------------------------------------------------------------
# Pick ONE provider to send cancellation emails from the browser. With neither set, the app opens
# the admin's mail client (mailto) instead — no email is lost, it just needs one tap to send.
#
# EmailJS (https://www.emailjs.com) — needs all three. Template must accept {{to_email}},
# {{subject}}, {{message}}.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
#
# OR Formspree (https://formspree.io) — a single form endpoint.
VITE_FORMSPREE_ENDPOINT=
