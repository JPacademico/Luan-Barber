# Copy to .env.local for local development, or set in Vercel > Settings > Environment Variables.
#
# WARNING: anything prefixed with VITE_ is compiled into the JavaScript sent to the browser.
# It is NOT secret — it only stays out of the git repository. Never put a real credential,
# API key or payment token in a VITE_ variable.

# --- Admin gate ---------------------------------------------------------------------------------
# FALLBACK ONLY. When VITE_API_BASE_URL is set, the password is verified by the backend against its
# ADMIN_PASSWORD secret and this value is ignored — that is what keeps it out of the JS bundle.
# This is used only when no backend is configured (local demo), where it is not real security.
VITE_ADMIN_PASSWORD=

# --- Cloud persistence (Supabase) ---------------------------------------------------------------
# BOTH must be set to turn on cross-device booking sync. Leave blank to fall back to per-device
# localStorage (the app still runs). The anon key is public by design — it is safe to ship because
# Row Level Security on the database decides what it can do. Run supabase/schema.sql once first.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Cancellation / booking e-mails ------------------------------------------------------------
# Sent by the backend automatically (database-triggered) — no frontend variables needed.
# The old client-side EmailJS / Formspree variables were removed and can be deleted from Vercel.

# --- Backend --------------------------------------------------------------------------------------
# Base URL of the Supabase Edge Functions, e.g. https://PROJECT_REF.functions.supabase.co.
# Leave blank to keep the simulated Pix flow and disable push notifications.
VITE_API_BASE_URL=

# --- Push notifications (admin) --------------------------------------------------------------------
# The PUBLIC key from `npx web-push generate-vapid-keys` (run in the backend repo). Both this and
# VITE_API_BASE_URL must be set for the admin's "Ativar notificações" button to do anything.
VITE_VAPID_PUBLIC_KEY=
